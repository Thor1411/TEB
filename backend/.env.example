# Backend environment configuration (copy to .env)

# Keep tokens stable across restarts
JWT_SECRET=aqwzrffdrct5xtxtfxhreghrshrkhgakgharkghjgheurhLARTA

# Keep encrypted PDFs readable across restarts.
# Must be 32 bytes, provided as base64 OR as 64 hex characters.
# Example to generate base64 on Linux:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# Optional but recommended: keep share links stable across restarts.
# Example:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SHARE_SECRET=

# Sharper sanitized/redacted PDFs (higher = sharper, slower)
SANITIZE_DPI=300

# Optional: require qpdf validation to run (fail if missing)
# REQUIRE_QPDF=1

# Optional: embedded signing
# PDF_SIGN_P12_PATH=./certs/test.p12
# PDF_SIGN_P12_PASSPHRASE=testpass
